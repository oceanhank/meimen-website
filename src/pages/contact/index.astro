---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPageBySlug } from '../../lib/wp-api';

const page = await getPageBySlug('contact');
const content = page?.content.rendered ?? '';
const formEndpoint = import.meta.env.FORMSPREE_ENDPOINT;
---

<BaseLayout title="聯絡我們 | 新竹美門社區關懷協會">
  <div class="page-hero">
    <div class="wrap"><h1 class="page-hero-title">聯絡我們</h1></div>
  </div>

  <div class="wrap contact-layout">
    <div class="contact-info">
      {content ? (
        <div class="wp-content" set:html={content} />
      ) : (
        <div class="contact-details">
          <h2>新竹美門社區關懷協會</h2>
          <p>📍 地址：新竹市 xxx 區 xxx 路 xxx 號</p>
          <p>📞 電話：(03) xxx-xxxx</p>
          <p>📧 Email：info@nghcc.org.tw</p>
          <p>⏰ 服務時間：週一至週五 09:00–17:00</p>
        </div>
      )}

      <div class="map-embed">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3622.0!2d120.9!3d24.8!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z5paw56u5!5e0!3m2!1szh-TW!2stw!4v1"
          width="100%"
          height="300"
          style="border:0; border-radius: var(--radius-box);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="新竹美門社區關懷協會地圖位置"
        ></iframe>
      </div>
    </div>

    <div class="contact-form-wrap">
      <h2 class="form-title">傳送訊息</h2>
      <form
        action={formEndpoint || 'https://formspree.io/f/placeholder'}
        method="POST"
        class="contact-form"
      >
        <label>
          <span>姓名 <span class="required" aria-hidden="true">*</span></span>
          <input type="text" name="name" required placeholder="您的姓名" />
        </label>
        <label>
          <span>Email <span class="required" aria-hidden="true">*</span></span>
          <input type="email" name="email" required placeholder="your@email.com" />
        </label>
        <label>
          <span>電話</span>
          <input type="tel" name="phone" placeholder="09xx-xxxxxx" />
        </label>
        <label>
          <span>訊息 <span class="required" aria-hidden="true">*</span></span>
          <textarea name="message" required rows="5" placeholder="請輸入您的訊息…"></textarea>
        </label>
        <button type="submit" class="submit-btn">送出訊息</button>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero { background: var(--color-bg-light); padding: 120px 0 60px; text-align: center; }
  .page-hero-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text-dark); }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    padding: 60px 0 100px;
    align-items: start;
  }

  .contact-details h2 { font-size: 1.4rem; font-weight: 700; color: var(--color-text-dark); margin-bottom: 20px; }
  .contact-details p { margin-bottom: 12px; color: var(--color-text-body); line-height: 1.8; }

  .map-embed { margin-top: 32px; }

  .wp-content :global(p) { margin-bottom: 12px; color: var(--color-text-body); line-height: 1.8; }

  .form-title { font-size: 1.4rem; font-weight: 700; color: var(--color-text-dark); margin-bottom: 28px; }

  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .contact-form label { display: flex; flex-direction: column; gap: 6px; }
  .contact-form span { font-size: 0.875rem; font-weight: 600; color: var(--color-text-dark); }
  .required { color: var(--color-accent); }
  .contact-form input,
  .contact-form textarea {
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-size: 0.95rem;
    font-family: var(--font-main);
    color: var(--color-text-body);
    background: var(--color-bg);
    transition: border-color 0.2s;
    resize: vertical;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .submit-btn {
    align-self: flex-start;
    padding: 14px 40px;
    background: var(--color-main);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
  }
  .submit-btn:hover { background: var(--color-accent); }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
