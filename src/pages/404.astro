---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="找不到頁面 | 新竹美門社區關懷協會">
  <div class="not-found-wrap">
    <div class="not-found-blob" aria-hidden="true"></div>
    <div class="not-found-content">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title">找不到這個頁面</h1>
      <p class="not-found-body">您要找的頁面可能已移除、更名，或暫時無法使用。</p>
      <a href="/" class="back-home">回到首頁</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found-wrap {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 20px 60px;
    position: relative;
    overflow: hidden;
  }
  .not-found-blob {
    position: absolute;
    width: 500px;
    height: 500px;
    background: var(--color-deco-pink);
    opacity: 0.2;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: lavaBlobSoft 12s ease-in-out infinite;
    pointer-events: none;
  }
  .not-found-content {
    position: relative;
    text-align: center;
    z-index: 1;
  }
  .not-found-code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: -16px;
  }
  .not-found-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 16px;
  }
  .not-found-body {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 36px;
  }
  .back-home {
    display: inline-block;
    padding: 14px 40px;
    background: var(--color-main);
    color: #fff;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.3s;
  }
  .back-home:hover { background: var(--color-accent); }
</style>
