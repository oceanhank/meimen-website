---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostsByCategory, CATEGORY_IDS } from '../../lib/wp-api';

export async function getStaticPaths() {
  const PER_PAGE = 9;
  const allPosts = await getPostsByCategory(CATEGORY_IDS.ARTICLE, { per_page: 100 });
  const totalPages = Math.ceil(allPosts.length / PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      posts: allPosts.slice(i * PER_PAGE, (i + 1) * PER_PAGE),
      currentPage: i + 1,
      totalPages,
    },
  }));
}

const { posts, currentPage, totalPages } = Astro.props;

function getExcerpt(html: string) {
  return html.replace(/<[^>]+>/g, '').slice(0, 100).trim();
}
function getFeaturedImage(post: typeof posts[0]) {
  return post._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? '/images/placeholder.jpg';
}
---

<BaseLayout title={`文章專欄 第 ${currentPage} 頁 | 新竹美門社區關懷協會`}>
  <div class="page-hero">
    <div class="wrap"><h1 class="page-hero-title">文章專欄</h1></div>
  </div>
  <div class="wrap page-content">
    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/article/${post.slug}/`} class="post-card">
          <div class="post-img-wrap">
            <img src={getFeaturedImage(post)} alt={post.title.rendered} loading="lazy" />
          </div>
          <div class="post-body">
            <h2 class="post-title" set:html={post.title.rendered} />
            <p class="post-excerpt">{getExcerpt(post.excerpt.rendered)}</p>
            <span class="read-more">閱讀更多 →</span>
          </div>
        </a>
      ))}
    </div>
    <nav class="pagination" aria-label="分頁導覽">
      {Array.from({ length: totalPages }, (_, i) => (
        <a href={`/article/${i + 1}/`} class={`page-link${i + 1 === currentPage ? ' active' : ''}`}
          aria-current={i + 1 === currentPage ? 'page' : undefined}>{i + 1}</a>
      ))}
    </nav>
  </div>
</BaseLayout>

<style>
  .page-hero { background: var(--color-bg-light); padding: 120px 0 60px; text-align: center; }
  .page-hero-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text-dark); }
  .page-content { padding: 60px 0 100px; }
  .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 48px; }
  .post-card { display: block; border-radius: var(--radius-box); overflow: hidden; box-shadow: var(--shadow-card);
    background: #fff; transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; }
  .post-card:hover { transform: translateY(-4px); box-shadow: 2px 8px 28px rgba(0,0,0,0.14); }
  .post-img-wrap img { width: 100%; height: 200px; object-fit: cover; }
  .post-body { padding: 20px; }
  .post-title { font-size: 1rem; font-weight: 600; color: var(--color-text-dark); margin-bottom: 8px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .post-excerpt { font-size: 0.875rem; color: var(--color-text-light); line-height: 1.7; margin-bottom: 12px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .read-more { font-size: 0.85rem; color: var(--color-accent); font-weight: 500; }
  .pagination { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .page-link { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px;
    border-radius: 50%; background: var(--color-bg-light); color: var(--color-text-body); font-size: 0.9rem;
    transition: var(--transition-fast); }
  .page-link:hover, .page-link.active { background: var(--color-accent); color: #fff; }
  @media (max-width: 991px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .post-grid { grid-template-columns: 1fr; } }
</style>
