---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, getPostBySlug } from '../../lib/wp-api';

export async function getStaticPaths() {
  const posts = await getPosts({ per_page: 100 });
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}

const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const featuredAlt = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text ?? post.title.rendered;
const formattedDate = new Date(post.date).toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={`${post.title.rendered} | 新竹美門社區關懷協會`}>
  {featuredImage && (
    <div class="post-hero">
      <img src={featuredImage} alt={featuredAlt} />
    </div>
  )}

  <div class="wrap post-content-wrap">
    <a href="/article/" class="back-link">← 返回文章列表</a>
    <h1 class="post-title" set:html={post.title.rendered} />
    <p class="post-date">{formattedDate}</p>
    <div class="wp-content" set:html={post.content.rendered} />
    <a href="/article/" class="back-link back-link-bottom">← 返回文章列表</a>
  </div>
</BaseLayout>

<style>
  .post-hero {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    margin-top: 72px;
  }
  .post-hero img { width: 100%; height: 480px; object-fit: cover; }

  .post-content-wrap { padding: 48px 0 100px; max-width: 800px; margin: 0 auto; }

  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .back-link:hover { opacity: 0.8; }
  .back-link-bottom { margin-top: 48px; margin-bottom: 0; }

  .post-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 12px;
    line-height: 1.35;
  }
  .post-date {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .wp-content :global(h2) { font-size: 1.4rem; font-weight: 700; color: var(--color-text-dark); margin: 32px 0 14px; }
  .wp-content :global(h3) { font-size: 1.2rem; font-weight: 600; color: var(--color-main); margin: 24px 0 10px; }
  .wp-content :global(p) { margin-bottom: 16px; color: var(--color-text-body); line-height: 1.9; }
  .wp-content :global(img) { border-radius: var(--radius-box); margin: 24px 0; }
  .wp-content :global(a) { color: var(--color-accent); text-decoration: underline; }
  .wp-content :global(ul), .wp-content :global(ol) {
    padding-left: 24px; margin-bottom: 16px; color: var(--color-text-body); line-height: 1.9;
  }
  .wp-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding: 12px 20px;
    background: var(--color-bg-light);
    border-radius: 0 var(--radius-box) var(--radius-box) 0;
    margin: 24px 0;
  }
</style>
