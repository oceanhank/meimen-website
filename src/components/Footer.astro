---
const year = new Date().getFullYear();
const footerNav = [
  { label: '關於我們', href: '/about/' },
  { label: '服務訊息', href: '/news/' },
  { label: '文章專欄', href: '/article/' },
  { label: '線上課程', href: '/course/' },
  { label: '聯絡我們', href: '/contact/' },
];
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-col footer-left">
      <p class="footer-tagline">「用愛服務，讓生命更豐盛」</p>
      <div class="footer-social">
        <a href="https://www.facebook.com/nghcc" target="_blank" rel="noopener" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@nghcc" target="_blank" rel="noopener" aria-label="YouTube">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
            <polygon fill="#fff" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-col footer-center">
      <a href="/" aria-label="回首頁">
        <img src="/logo-white.svg" alt="美門 LOGO" class="footer-logo" width="120" height="48" />
      </a>
    </div>

    <div class="footer-col footer-right">
      <ul class="footer-nav">
        {footerNav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <p class="footer-copyright">© {year} 新竹美門社區關懷協會 All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-main);
    color: rgba(255, 255, 255, 0.85);
    padding: 60px 0 40px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 40px;
  }

  .footer-tagline {
    font-size: 1rem;
    font-style: italic;
    margin-bottom: 16px;
    color: var(--color-deco-cream);
  }

  .footer-social {
    display: flex;
    gap: 12px;
    color: rgba(255, 255, 255, 0.75);
  }
  .footer-social a:hover { color: var(--color-accent); }

  .footer-center { text-align: center; }
  .footer-logo { height: 56px; width: auto; opacity: 0.9; }

  .footer-right { text-align: right; }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 4px 16px;
    list-style: none;
    margin-bottom: 16px;
  }
  .footer-nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.75);
  }
  .footer-nav a:hover { color: var(--color-accent); }

  .footer-copyright {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 767px) {
    .footer-inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      text-align: center;
    }
    /* Mobile order: center logo → left tagline+social → right nav+copyright */
    .footer-center { order: -1; }
    .footer-left { order: 0; }
    .footer-right { order: 1; text-align: center; }
    .footer-social { justify-content: center; }
    .footer-nav { justify-content: center; }
  }
</style>
